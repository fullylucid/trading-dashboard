# Hermes Trading Dashboard - Configuration
# =============================================
# CRITICAL: This file is .gitignored. Never commit secrets to git.
# Copy this to .env and fill in your values.

# Telegram Bot Configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Ollama Cloud API Configuration (for Charlotte v4 LLM layer)
# Models: kimi-k2.6:cloud (primary), qwen3-coder:480b-cloud (secondary)
OLLAMA_API_KEY=your_ollama_cloud_api_key_here
OLLAMA_BASE_URL=https://api.ollama.cloud/v1

# SnapTrade Integration
SNAPTRADE_CLIENT_ID=your_snaptrade_client_id
SNAPTRADE_SIGNATURE_KEY=your_snaptrade_signature_key
SNAPTRADE_USER_ID=your_snaptrade_user_id

# Market Data APIs
ALPHA_VANTAGE_KEY=your_alpha_vantage_key
FINNHUB_API_KEY=your_finnhub_api_key
TIINGO_API_KEY=your_tiingo_api_key

# Trading Configuration
MIN_SIGNAL_CONFIDENCE=6.0
MARKET_DATA_CACHE_HOURS=24

# System Monitoring Thresholds
CPU_ALERT_THRESHOLD=75
MEMORY_ALERT_THRESHOLD=80
DISK_ALERT_THRESHOLD=90
